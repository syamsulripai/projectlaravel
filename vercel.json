{
  "version": 2,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.3"
    }
  },
  "routes":  [
        {
            "src": "/build/(.*)",
            "dest": "/public/build/$1"
        },
        {
            "src": "/favicon.ico",
            "dest": "/public/favicon.ico"
        },
        {
            "src": "/assets/(.*)",
            "dest": "/public/assets/$1"
        },
        {
            "src": "/bootstrap-5.3.8-dist/(.*)",
            "dest": "/bootstrap-5.3.8-dist/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
      "APP_ENV": "local",
      "APP_DEBUG": "true",
      "SESSION_DRIVER": "cookie", 
      "CACHE_STORE": "array",
      "LOG_CHANNEL": "stderr",
      "APP_SERVICES_CACHE": "/tmp/services.php",
      "APP_PACKAGES_CACHE": "/tmp/packages.php",
      "APP_ROUTES_CACHE": "/tmp/routes.php",
      "APP_CONFIG_CACHE": "/tmp/config.php"
  }
}